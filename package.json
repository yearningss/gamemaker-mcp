{
  "name": "gamemaker-mcp",
  "version": "1.20.0",
  "description": "A safe, project-aware MCP server for GameMaker Studio",
  "type": "module",
  "bin": {
    "gamemaker-mcp": "dist/src/index.js"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/src/index.js",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "test": "npm run build && cd dist && node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "jsonc-parser": "3.3.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "typescript": "5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yearningss/gamemaker-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/yearningss/gamemaker-mcp/issues"
  },
  "homepage": "https://github.com/yearningss/gamemaker-mcp#readme",
  "license": "MIT"
}
